{
    "name": "zillur/laravel-web-terminal",
    "description": "Secure web-based Laravel Artisan terminal",
    "keywords": ["laravel", "artisan", "terminal", "web-terminal"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Zillur Web",
            "email": "zillur.web@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Zillur\\WebTerminal\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zillur\\WebTerminal\\WebTerminalServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}