{
    "name": "zillur-web/laravel-web-terminal",
    "description": "Secure web-based Laravel Artisan terminal for browser",
    "type": "library",
    "license": "MIT",
    "authors": [
        {"name": "Zillur Rahman", "email": "zillur.web@gmail.com"}
    ],
    "require": {
        "php": "^8.0 <=8.5",
        "illuminate/support": "^8.0|^9.0|^10.0|^12.0"
    },
    "autoload": {
        "psr-4": {"Zillur\\WebTerminal\\": "src/"}
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zillur\\WebTerminal\\WebTerminalServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}