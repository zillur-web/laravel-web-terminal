{
    "name": "zillur-web/laravel-web-terminal",
    "description": "A secure web-based Laravel Artisan terminal to run selected commands from the browser",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Zillur Rahman",
            "email": "your@email.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Zillur\\WebTerminal\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zillur\\WebTerminal\\WebTerminalServiceProvider"
            ]
        }
    }
}